# To create or update a token visit https://envio.dev/app/api-tokens
ENVIO_API_TOKEN="<YOUR-API-TOKEN>"

# Single dRPC key for all chains (effects use this to build per-chain URLs)
ENVIO_DRPC_KEY="<YOUR-DRPC-KEY>"

# Or set per-chain RPC URLs individually (overrides ENVIO_DRPC_KEY for that chain):
# ENVIO_RPC_URL_1="https://eth-mainnet.g.alchemy.com/v2/..."
# ENVIO_RPC_URL_42161="https://arb-mainnet.g.alchemy.com/v2/..."
